# BiziApp — Configuration secrets (EXEMPLE)
# ⚠ Copiez ce fichier en secrets.toml sur Streamlit Cloud (Settings → Secrets)
# NE commitez JAMAIS le vrai secrets.toml

# ── Authentification utilisateurs ─────────────────────────────────────────────
# La DB utilisateurs est stockée en JSON dans users_db
# En production, chaque utilisateur est persisté ici
[users_db]
# Laisser vide au démarrage — BiziApp gère automatiquement
# Exemple (ne pas mettre en prod) : '{"user@example.com": {"email":"...","name":"..."}}'

# ── OAuth Providers (optionnel — connexion sociale) ───────────────────────────
[oauth]
# Google OAuth 2.0 — Créer sur console.cloud.google.com
# 1. Créer un projet → APIs → Identifiants → ID client OAuth 2.0
# 2. Type : Application Web
# 3. Origines autorisées : https://votre-app.streamlit.app
# 4. URI de redirection : https://votre-app.streamlit.app
google_client_id = ""
google_client_secret = ""  # Non utilisé (PKCE flow)

# GitHub OAuth — Créer sur github.com/settings/developers
# 1. New OAuth App → Homepage URL + Callback URL = votre app Streamlit
github_client_id = ""
github_client_secret = ""  # Non utilisé (PKCE flow)

# Microsoft/Hotmail — Azure App Registration (portal.azure.com)
microsoft_client_id = ""

# Yahoo OAuth — developer.yahoo.com
yahoo_client_id = ""

# Shopify OAuth — partners.shopify.com
shopify_api_key = ""

# ── APIs externes (toutes optionnelles) ──────────────────────────────────────
[api]
# Google PageSpeed Insights (heuristique si absent)
pagespeed_api_key = ""
# OpenAI — analyses enrichies (templates statiques si absent)
openai_api_key = ""

# ── Sécurité ──────────────────────────────────────────────────────────────────
[security]
# Clé secrète pour les tokens (générer : python3 -c "import secrets; print(secrets.token_hex(32))")
secret_key = "changez-cette-cle-min-32-chars-obligatoire"
