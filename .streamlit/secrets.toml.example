# BiziApp — Configuration secrets (EXEMPLE)
# ⚠ Copiez ce fichier en secrets.toml et NE le commitez JAMAIS
# Le vrai secrets.toml est dans .gitignore

[auth]
# Activez l'authentification par mot de passe
enabled = true
# Choisissez un mot de passe fort (min 12 caractères)
password = "changez-ce-mot-de-passe-fort-ici"

[api]
# Clé Google PageSpeed Insights (optionnel — mock si absent)
pagespeed_api_key = ""
# Clé OpenAI (optionnel — templates statiques si absent)
openai_api_key = ""
