# ── Stratège Backend — Variables d'environnement ──────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs AVANT de lancer le serveur
# ⚠ Ne commitez JAMAIS le fichier .env (il est dans .gitignore)

# Environnement : development | production
ENVIRONMENT=production

# ── Base de données ───────────────────────────────────────────────────────────
# PostgreSQL en production (Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/stratege
# Si pas de PostgreSQL, laissez vide → SQLite local automatique
# DATABASE_URL=

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Clé secrète pour les tokens (générez avec: python3 -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changez-cette-cle-secrete-obligatoire

# ── Docker (si docker-compose) ────────────────────────────────────────────────
DB_USER=stratege
DB_PASSWORD=changez-ce-mot-de-passe-db
DB_NAME=stratege

# ── CORS — origines autorisées (séparées par virgule) ────────────────────────
# En dev, laissez vide → localhost:3000 automatique
# En prod: mettez votre domaine Vercel ou custom
ALLOWED_ORIGINS=https://votre-frontend.vercel.app

# ── APIs externes (toutes optionnelles) ──────────────────────────────────────
# Google PageSpeed Insights (https://console.cloud.google.com)
PAGESPEED_API_KEY=

# OpenAI — pour analyses enrichies (fallback templates si absent)
OPENAI_API_KEY=
