# ── Stratège Backend — Variables d'environnement ──────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs

# Environnement : development | production
ENVIRONMENT=development

# Mode debug (active le rechargement automatique uvicorn)
DEBUG=true

# Clé API Google PageSpeed Insights (optionnel)
# Sans clé, l'analyse PageSpeed utilise des données simulées
# Obtenez une clé sur : https://console.cloud.google.com
# PAGESPEED_API_KEY=AIzaSy...

# CORS — liste des origines autorisées (séparées par virgule)
# En dev, laissez vide pour autoriser localhost:3000 automatiquement
# ALLOWED_ORIGINS=https://votre-domaine.fr
