# ── Variables d'environnement racine (pour docker-compose) ───────────────────
# Copiez en .env et remplissez. Ne commitez JAMAIS ce fichier.

# ── Secrets obligatoires ──────────────────────────────────────────────────────
SECRET_KEY=changez-cette-cle-secrete-min-32-chars
DB_PASSWORD=changez-ce-mot-de-passe-db-fort

# ── Base de données Docker ────────────────────────────────────────────────────
DB_USER=stratege
DB_NAME=stratege

# ── CORS Frontend ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── APIs externes (optionnel) ─────────────────────────────────────────────────
OPENAI_API_KEY=
PAGESPEED_API_KEY=
